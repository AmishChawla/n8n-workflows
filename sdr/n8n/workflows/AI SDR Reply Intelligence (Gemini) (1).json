        "jsCode": "const items = $input.all();\n\n// Lead details\nconst lead = items[0].json;\n\n// Calendar events\nconst events = items.slice(1).map(i => i.json);\n\nconst startHour = 9;\nconst endHour = 18;\nconst slotDuration = 30;\n\nconst busySlots = events.map(event => ({\n  start: new Date(event.start.dateTime),\n  end: new Date(event.end.dateTime)\n}));\n\nfunction isBusy(start, end) {\n  return busySlots.some(b =>\n    start < b.end && end > b.start\n  );\n}\n\nlet today = new Date();\nlet candidateSlots = [];\n\n// Check next 5 days (skip today)\nfor (let d = 1; d <= 5; d++) {\n\n  let day = new Date();\n  day.setDate(today.getDate() + d);\n  day.setHours(0,0,0,0);\n\n  for (let hour = startHour; hour < endHour; hour++) {\n\n    for (let min = 0; min < 60; min += slotDuration) {\n\n      let slotStart = new Date(day);\n      slotStart.setHours(hour, min, 0);\n\n      let slotEnd = new Date(slotStart);\n      slotEnd.setMinutes(slotStart.getMinutes() + slotDuration);\n\n      if (!isBusy(slotStart, slotEnd)) {\n\n        candidateSlots.push({\n          date: d,\n          formatted: slotStart.toLocaleString(\"en-IN\", {\n            dateStyle: \"medium\",\n            timeStyle: \"short\"\n          })\n        });\n\n      }\n\n    }\n  }\n}\n\n// Shuffle slots\ncandidateSlots.sort(() => Math.random() - 0.5);\n\n// Pick 2 slots from different days\nlet selected = [];\nlet usedDays = new Set();\n\nfor (let slot of candidateSlots) {\n  if (!usedDays.has(slot.date)) {\n    selected.push(slot.formatted);\n    usedDays.add(slot.date);\n  }\n  if (selected.length === 2) break;\n}\n\nreturn [{\n  json: {\n    name: lead.Name,\n    email: lead.Email,\n    mobile: lead.Mobile,\n    message: lead.Message,\n    available_slots: selected\n  }\n}];"
      },
