    {
      "parameters": {
        "jsCode": "const slot1 = $input.first().json.available_slots[0];\nconst slot2 = $input.first().json.available_slots[1];\n\nconst mail = `\nHi,\n\nThe time you requested is unfortunately not available.\n\nHowever, here are two available slots:\n\n1️⃣ ${slot1}  \n2️⃣ ${slot2}\n\nPlease reply whichever slot works for you, and I will schedule the meeting for you right away.\n\nLooking forward to speaking with you.\n\nBest regards,\nTeam\n`;\n\nreturn [\n  {\n    json: {\n      mail: mail\n    }\n  }\n];"
      },
