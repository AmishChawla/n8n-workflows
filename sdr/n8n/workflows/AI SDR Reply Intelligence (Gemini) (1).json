      ],
      "id": "6433b304-52cf-4210-8b35-71449184d9c6",
      "name": "Turn context into string"
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n\n  const text = $input.first().json.text || \"\";\n\n  // Remove quoted previous emails (Gmail / Outlook / Apple Mail patterns)\n  const cleaned = text\n    .replace(/On\\s.+?wrote:[\\s\\S]*/gi, \"\")\n    .replace(/From:\\s.+[\\s\\S]*/gi, \"\")\n    .replace(/-----Original Message-----[\\s\\S]*/gi, \"\")\n    .replace(/>.+/g, \"\")\n    .trim();\n\n  return {\n    json: {\n      message_id: item.json.id,\n      threadId: item.json.threadId,\n      message: cleaned,\n      from: item.json.from?.value?.[0]?.address || \"\",\n      subject: item.json.subject\n    }\n  };\n});"
      },
