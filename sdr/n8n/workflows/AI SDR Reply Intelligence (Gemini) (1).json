{
  "name": "AI SDR Reply Intelligence (Gemini)",
  "nodes": [
    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-lite:generateContent?key=YOUR_GEMINI_API_KEY",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [\n    {\n      \"parts\": [\n        {\n          \"text\": \"You are an AI intent classifier and meeting time extractor.\\n\\nCurrent date and time in Asia/Kolkata timezone (reference for calculations): {{ $now.setZone('Asia/Kolkata').toISO() }}\\nTimezone for all calculations and outputs: Asia/Kolkata\\n\\nYour job is to analyze a user message and return:\\n1. The user's intent\\n2. The time mentioned in natural language\\n3. The same time converted to ISO datetime if possible\\n\\nPossible intents:\\nBookMeeting\\nQuestionHandler\\nObjectionHandler\\n\\nRules:\\n- Always return valid JSON.\\n- Do NOT include explanations or extra text.\\n- Return only the JSON object.\\n- If no time is mentioned, set time_text and datetime to null.\\n- Use the provided current date as the reference when calculating relative times such as tomorrow, next week, or next Tuesday.\\n- All datetime values must be returned in Asia/Kolkata timezone.\\n- Datetime must use ISO 8601 format with the +05:30 offset.\\n- If the exact date cannot be determined, set datetime to null.\\n\\nOutput format:\\n{\\n  \\\"intent\\\": \\\"BookMeeting | QuestionHandler | ObjectionHandler\\\",\\n  \\\"time_text\\\": \\\"string or null\\\",\\n  \\\"datetime\\\": \\\"ISO 8601 Asia/Kolkata datetime or null\\\"\\n}\\n\\nIntent definitions:\\n\\nBookMeeting:\\nUser wants to schedule, confirm, or discuss a call OR mentions availability.\\n\\nQuestionHandler:\\nUser asks about services, pricing, process, or information.\\n\\nObjectionHandler:\\nUser expresses hesitation, rejection, concern, or lack of interest.\\n\\nExamples:\\n\\nUser: Can we schedule a call for next Tuesday?\\nOutput:\\n{\\n  \\\"intent\\\": \\\"BookMeeting\\\",\\n  \\\"time_text\\\": \\\"next Tuesday\\\",\\n  \\\"datetime\\\": null\\n}\\n\\nUser: Call me tomorrow at 3pm\\nOutput:\\n{\\n  \\\"intent\\\": \\\"BookMeeting\\\",\\n  \\\"time_text\\\": \\\"tomorrow 3pm\\\",\\n  \\\"datetime\\\": \\\"2026-03-09T15:00:00+05:30\\\"\\n}\\n\\nUser: Sure let's talk\\nOutput:\\n{\\n  \\\"intent\\\": \\\"BookMeeting\\\",\\n  \\\"time_text\\\": null,\\n  \\\"datetime\\\": null\\n}\\n\\nUser: I'm not free today, call tomorrow\\nOutput:\\n{\\n  \\\"intent\\\": \\\"BookMeeting\\\",\\n  \\\"time_text\\\": \\\"tomorrow\\\",\\n  \\\"datetime\\\": null\\n}\\n\\nUser: Can you tell me your pricing?\\nOutput:\\n{\\n  \\\"intent\\\": \\\"QuestionHandler\\\",\\n  \\\"time_text\\\": null,\\n  \\\"datetime\\\": null\\n}\\n\\nUser: That's too expensive\\nOutput:\\n{\\n  \\\"intent\\\": \\\"ObjectionHandler\\\",\\n  \\\"time_text\\\": null,\\n  \\\"datetime\\\": null\\n}\\n\\nNow analyze this user message:\\n{{ $('Cleaned Message').item.json.message }}\"\n        }\n      ]\n    }\n  ],\n  \"generationConfig\": {\n    \"temperature\": 0,\n    \"response_mime_type\": \"application/json\"\n  }\n}",
        "options": {}
      },
