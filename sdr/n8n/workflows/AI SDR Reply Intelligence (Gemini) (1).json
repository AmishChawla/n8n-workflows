    {
      "parameters": {
        "jsCode": "const messages = $input.all();\n\nconst contents = [];\n\nfor (const item of messages) {\n\n  const msg = item.json;\n\n  if (msg.human) {\n    contents.push({\n      role: \"user\",\n      parts: [{ text: msg.human }]\n    });\n  }\n\n  if (msg.ai) {\n    contents.push({\n      role: \"model\",\n      parts: [{ text: msg.ai }]\n    });\n  }\n\n}\n\nconst latestMessage=$('Cleaned Message').first().json.message;\n\ncontents.push({\n      role: \"user\",\n      parts: [{ text: latestMessage }]\n    });\n\nreturn [\n  {\n    json: {\n      contents\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
